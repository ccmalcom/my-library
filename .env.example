# Copy to .env and fill in. .env is gitignored.

# Required for the taste-profile step (Claude). Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model used for the taste-profile extractor.
MYLIBRARY_MODEL=claude-sonnet-4-6

# Optional. Google Books works without a key but a free key raises rate limits.
# https://developers.google.com/books/docs/v1/using#APIKey
GOOGLE_BOOKS_API_KEY=

# Optional. Where data, cache, and the SQLite db live (defaults to ./data).
# MYLIBRARY_DATA_DIR=data
