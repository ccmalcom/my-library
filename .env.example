# MyLibrary environment — copy to .env and fill in. .env is gitignored.
#
# LOCAL MODE (default): leave all the "web distribution" vars below unset. The app runs
# single-user against a local SQLite file, exactly as before. Only ANTHROPIC_API_KEY (for
# profile/recommend) and optionally GOOGLE_BOOKS_API_KEY are needed.

# --- local single-user ---
ANTHROPIC_API_KEY=
GOOGLE_BOOKS_API_KEY=          # optional; bundled shared key in hosted mode
# MYLIBRARY_MODEL=claude-sonnet-4-6
# MYLIBRARY_REQ_PER_SEC=8
# MYLIBRARY_DATA_DIR=data

# --- web distribution (hosted multi-tenant mode) ---
# Setting DATABASE_URL flips the app into multi-tenant mode (Postgres instead of SQLite).
# Use the Supabase SESSION POOLER string (host aws-0-<region>.pooler.supabase.com, port 5432):
# it's IPv4 and supports DDL/prepared statements. Avoid the direct connection (IPv6-only) and
# the transaction pooler (port 6543 — breaks DDL under psycopg3). Driver MUST be psycopg v3;
# config.db_url auto-pins a bare postgresql:// (or legacy postgres://) to +psycopg, but prefer
# writing it explicitly. URL-encode special chars in the password (@ -> %40, etc.).
# Full steps: mylibrary-postgres-cutover-runbook.md
# DATABASE_URL=postgresql+psycopg://postgres.<ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Supabase auth. New projects sign access tokens with ES256 (asymmetric): the backend
# verifies against the project's PUBLIC key from the JWKS endpoint — no shared secret.
# Set SUPABASE_URL (the project URL, e.g. https://abc123.supabase.co); the JWKS URL is
# derived as <SUPABASE_URL>/auth/v1/.well-known/jwks.json. When unset, auth is disabled
# (local mode) and all data belongs to the "local" user.
# SUPABASE_URL=
# SUPABASE_JWKS_URL=          # optional explicit override of the derived JWKS URL
# SUPABASE_JWT_SECRET=        # legacy HS256 fallback only (older projects); leave unset for ES256

# Base64 32-byte key for AES-256-GCM encryption of each user's Anthropic key at rest.
# Generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
# ENCRYPTION_KEY=

# Redis URL for the arq background job queue (Phase 4 — enrichment runs as a background job).
# Upstash Redis (recommended for Railway): rediss://<user>:<token>@<host>.upstash.io:6379
# Local Redis: redis://localhost:6379
# When unset: enrichment falls back to FastAPI BackgroundTasks (fine for local dev; no Redis needed).
# REDIS_URL=
