# MyLibrary environment — copy to .env and fill in. .env is gitignored.
#
# LOCAL MODE (default): leave all the "web distribution" vars below unset. The app runs
# single-user against a local SQLite file, exactly as before. Only ANTHROPIC_API_KEY (for
# profile/recommend) and optionally GOOGLE_BOOKS_API_KEY are needed.

# --- local single-user ---
ANTHROPIC_API_KEY=
GOOGLE_BOOKS_API_KEY=          # optional; bundled shared key in hosted mode
# MYLIBRARY_MODEL=claude-sonnet-4-6
# MYLIBRARY_REQ_PER_SEC=8
# MYLIBRARY_DATA_DIR=data

# --- web distribution (hosted multi-tenant mode) ---
# Setting DATABASE_URL flips the app into multi-tenant mode (Postgres instead of SQLite).
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/postgres

# Supabase access-token verification (HS256). Found in Supabase project settings.
# When unset, auth is disabled (local mode) and all data belongs to the "local" user.
# SUPABASE_JWT_SECRET=

# Base64 32-byte key for AES-256-GCM encryption of each user's Anthropic key at rest.
# Generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
# ENCRYPTION_KEY=
